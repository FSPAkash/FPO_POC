:root {
  --green-900: #1b5e20;
  --green-700: #2d6f33;
  --green-600: #388e3c;
  --green-500: #4caf50;
  --green-300: #81c784;
  --green-200: #a8dca8;
  --green-100: #cbe6c8;
  --green-50: #e6f4ea;
  --white: #ffffff;
  --bg-base: #f2f6f2;
  --bg-mesh-opacity: 0.18;
  --glass-light: rgba(255, 255, 255, 0.42);
  --glass-normal: rgba(255, 255, 255, 0.58);
  --glass-strong: rgba(255, 255, 255, 0.74);
  --surface-inset: rgba(27, 94, 32, 0.04);
  --green-tint-bg: rgba(76, 175, 80, 0.08);
  --gray-50: #f5f7f5;
  --gray-100: #e8ece8;
  --gray-200: #d0d5d0;
  --gray-300: #b0b8b0;
  --gray-400: #8a928a;
  --gray-500: #6b736b;
  --gray-600: #4a524a;
  --gray-700: #2d332d;
  --gray-800: #1a1f1a;
  --red-500: #ef5350;
  --amber-500: #ffa726;
  --text-xs: 11px;
  --text-sm: 13px;
  --text-base: 15px;
  --text-lg: 22px;
  --text-xl: 28px;
  --space-1: 6px;
  --space-2: 12px;
  --space-3: 20px;
  --space-4: 32px;
  --space-5: 48px;
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 20px;
  --radius-pill: 100px;
  --border-glass: 1px solid rgba(203, 230, 200, 0.28);
  --border-subtle: 1px solid rgba(203, 230, 200, 0.18);
  --font-sans: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
}

*,
*::before,
*::after {
  box-sizing: border-box;
}

html,
body,
#root {
  margin: 0;
  min-height: 100%;
}

body {
  min-height: 100vh;
  font-family: var(--font-sans);
  color: var(--gray-800);
  background: var(--bg-base);
}

button,
input,
select,
textarea {
  font: inherit;
}

button {
  border: 0;
}

.app-root {
  min-height: 100vh;
  position: relative;
  isolation: isolate;
}

.aurora-wrap {
  position: fixed;
  inset: 0;
  z-index: -1;
  overflow: hidden;
  pointer-events: none;
}

.mesh {
  position: absolute;
  border-radius: 50%;
  filter: blur(82px);
  opacity: var(--bg-mesh-opacity);
}

.mesh-1 {
  width: min(42vw, 520px);
  height: min(42vw, 520px);
  top: -7%;
  left: -7%;
  background: rgba(203, 230, 200, 0.85);
  animation: meshDrift1 52s ease-in-out infinite;
}

.mesh-2 {
  width: min(36vw, 440px);
  height: min(36vw, 440px);
  top: -5%;
  right: -7%;
  background: rgba(230, 244, 234, 0.92);
  animation: meshDrift2 64s ease-in-out infinite;
}

.mesh-3 {
  width: min(28vw, 360px);
  height: min(28vw, 360px);
  top: 30%;
  right: 10%;
  background: rgba(168, 220, 168, 0.78);
  animation: meshBreathe 18s ease-in-out infinite;
}

.mesh-4 {
  width: min(38vw, 480px);
  height: min(38vw, 480px);
  bottom: -12%;
  left: -4%;
  background: rgba(230, 244, 234, 0.92);
  animation: meshDrift3 44s ease-in-out infinite;
}

.mesh-5 {
  width: min(22vw, 280px);
  height: min(22vw, 280px);
  bottom: 3%;
  right: 4%;
  background: rgba(168, 220, 168, 0.3);
  animation: meshDrift4 70s ease-in-out infinite;
}

.mesh-6 {
  width: min(18vw, 240px);
  height: min(18vw, 240px);
  top: 41%;
  left: 46%;
  background: rgba(203, 230, 200, 0.2);
  animation: meshBreathe 22s ease-in-out infinite;
}

.glass-light,
.glass-normal,
.glass-strong {
  border-radius: var(--radius-lg);
  backdrop-filter: blur(24px);
}

.glass-light {
  background: var(--glass-light);
  border: var(--border-glass);
}

.glass-normal {
  background: var(--glass-normal);
  border: var(--border-glass);
}

.glass-strong {
  background: var(--glass-strong);
  border: var(--border-glass);
}

.top-bar {
  height: 60px;
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 40;
  border-radius: 0;
  border-left: 0;
  border-right: 0;
  border-top: 0;
  box-shadow: 0 8px 24px rgba(27, 94, 32, 0.06);
}

.brand-wrap,
.top-actions {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.brand-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--green-900), var(--green-500));
  color: var(--white);
  display: grid;
  place-items: center;
  font-size: var(--text-sm);
  font-weight: 700;
}

.brand-title {
  margin: 0;
  font-size: var(--text-base);
  font-weight: 500;
  color: var(--gray-700);
}

.nav-collapse-btn {
  width: 28px;
  height: 28px;
  border-radius: var(--radius-sm);
  background: transparent;
  color: var(--gray-500);
  border: var(--border-subtle);
  cursor: pointer;
  transition: all 0.2s ease;
}

.nav-collapse-btn:hover,
.btn-ghost:hover,
.pill-tab:hover,
.office-row:hover,
.comm-inbox-row:hover,
.nav-item:hover {
  background: var(--green-tint-bg);
  border-color: rgba(129, 199, 132, 0.6);
  color: var(--green-700);
}

.meta-pill,
.role-switch-wrap {
  height: 32px;
  border-radius: var(--radius-pill);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0 12px;
  background: var(--glass-light);
  border: var(--border-glass);
  color: var(--gray-500);
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.meta-label {
  font-size: var(--text-xs);
}

.seed-meta input,
.role-switch-wrap select {
  border: 0;
  background: transparent;
  color: var(--gray-700);
  font-size: var(--text-sm);
  min-width: 48px;
  outline: none;
}

.role-switch-wrap span {
  font-size: var(--text-xs);
}

.main-layout {
  display: grid;
  grid-template-columns: 220px minmax(0, 1fr);
  gap: 0;
}

.main-layout.nav-collapsed {
  grid-template-columns: 52px minmax(0, 1fr);
}

.left-nav {
  position: sticky;
  top: 60px;
  align-self: start;
  margin: 16px 0 16px 16px;
  padding: 10px 6px;
}

.nav-item {
  width: 100%;
  height: 40px;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0 12px;
  border-radius: var(--radius-md);
  background: transparent;
  color: var(--gray-600);
  cursor: pointer;
  position: relative;
  transition: all 0.2s ease;
}

.nav-item + .nav-item {
  margin-top: 4px;
}

.nav-item.active {
  background: var(--green-tint-bg);
  color: var(--green-700);
}

.nav-item.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 8px;
  bottom: 8px;
  width: 3px;
  border-radius: 999px;
  background: var(--green-500);
}

.nav-glyph {
  width: 22px;
  font-size: var(--text-xs);
  font-weight: 700;
  text-align: center;
  flex-shrink: 0;
}

.nav-label {
  font-size: var(--text-base);
  font-weight: 500;
}

.nav-item-icon {
  justify-content: center;
  padding: 0;
}

.content-wrap {
  min-width: 0;
  padding: 20px 24px;
}

.section-panel {
  max-width: 1440px;
  margin: 0 auto;
  animation: fadeInUp 0.25s ease;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--space-2);
  margin-bottom: var(--space-2);
}

.section-header h2 {
  margin: 0;
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--gray-800);
}

.section-subtitle {
  margin: 4px 0 0;
  max-width: 760px;
  font-size: var(--text-sm);
  color: var(--gray-500);
}

.stack {
  display: grid;
  gap: var(--space-2);
}

.section-toolbar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.content-block-head,
.reply-form-actions,
.drawer-button-stack,
.toolbar-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: var(--space-2);
  width: 100%;
}

.dashboard-stat-grid {
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
}

.equal-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-2);
}

.market-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
  gap: var(--space-2);
}

.communication-grid {
  display: grid;
  grid-template-columns: 1.05fr 1.35fr 1fr;
  gap: var(--space-2);
}

.stat-card {
  padding: 14px 16px;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.stat-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-2);
}

.stat-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin: 0;
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--gray-500);
}

.stat-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.tone-high {
  background: var(--red-500);
}

.tone-medium {
  background: var(--amber-500);
}

.tone-normal {
  background: var(--green-500);
}

.tone-neutral {
  background: var(--gray-400);
}

.stat-value {
  margin: 0;
  font-size: var(--text-lg);
  font-weight: 600;
  color: var(--gray-800);
  font-variant-numeric: tabular-nums;
}

.stat-helper {
  margin: 0;
  font-size: var(--text-xs);
  color: var(--gray-400);
}

.badge {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 20px;
  padding: 3px 8px;
  border-radius: var(--radius-pill);
  font-size: var(--text-xs);
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.badge-high {
  background: rgba(239, 83, 80, 0.12);
  color: var(--red-500);
}

.badge-medium {
  background: rgba(255, 167, 38, 0.16);
  color: #d87d08;
}

.badge-normal {
  background: rgba(76, 175, 80, 0.14);
  color: var(--green-700);
}

.badge-neutral {
  background: rgba(138, 146, 138, 0.12);
  color: var(--gray-500);
}

.btn-primary,
.btn-ghost {
  height: 36px;
  padding: 0 18px;
  border-radius: var(--radius-md);
  font-size: var(--text-sm);
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
}

.btn-primary {
  color: var(--white);
  background: linear-gradient(135deg, #1b5e20 0%, #388e3c 100%);
  box-shadow: 0 10px 24px rgba(27, 94, 32, 0.12);
}

.btn-primary:hover {
  transform: translateY(-1px);
  filter: brightness(1.05);
}

.btn-ghost {
  border: 1px solid rgba(203, 230, 200, 0.7);
  background: transparent;
  color: var(--gray-600);
}

.btn-small {
  height: 28px;
  padding: 0 10px;
  font-size: var(--text-xs);
}

.btn-icon {
  width: 32px;
  padding: 0;
}

.btn-primary:disabled,
.btn-ghost:disabled,
.wa-send-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.content-block h3,
.narrative-card h3 {
  margin: 0;
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--gray-700);
}

.content-block-head {
  margin-bottom: 8px;
}

.content-block-actions {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.table-card,
.narrative-card,
.comm-column {
  padding: 14px 16px;
}

.communication-jira-shell {
  height: clamp(560px, 76vh, 760px);
  overflow: hidden;
}

.communication-jira-shell .jira-board-layout {
  height: 100%;
  min-height: 0;
}

.office-console {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  max-height: 700px;
  overflow-y: auto;
}

.table-shell {
  display: grid;
  gap: var(--space-2);
}

.table-controls {
  display: grid;
  gap: 12px;
  padding: 4px 0 10px;
}

.table-filter-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: 10px;
}

.table-control {
  display: grid;
  gap: 6px;
}

.table-control span,
.table-controls-summary {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--gray-500);
}

.table-control-search input,
.table-control input,
.table-control select {
  width: 100%;
  height: 38px;
  padding: 0 12px;
  border-radius: var(--radius-md);
  border: var(--border-glass);
  background: rgba(255, 255, 255, 0.58);
  color: var(--gray-700);
}

.table-control-search input:focus,
.table-control input:focus,
.table-control select:focus {
  outline: 2px solid rgba(76, 175, 80, 0.18);
  outline-offset: 1px;
  border-color: rgba(129, 199, 132, 0.72);
}

.table-controls-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
}

.table-empty-filtered {
  min-height: 120px;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.28);
  border: var(--border-subtle);
}

.table-wrap {
  overflow-x: auto;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
}

.data-table thead tr {
  background: var(--surface-inset);
}

.data-table th,
.data-table td {
  padding: 0 14px;
  height: 40px;
  text-align: left;
  font-size: var(--text-sm);
  color: var(--gray-700);
  border-bottom: var(--border-subtle);
  white-space: nowrap;
}

.data-table th {
  font-size: var(--text-xs);
  color: var(--gray-500);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.data-table tbody tr:nth-child(even) td {
  background: var(--surface-inset);
}

.data-table tbody tr:hover td {
  background: var(--green-tint-bg);
}

.table-pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--gray-500);
}

.table-pagination-actions {
  display: flex;
  gap: 8px;
}

.table-empty {
  min-height: 168px;
  display: grid;
  place-items: center;
  gap: 8px;
  text-align: center;
  color: var(--gray-500);
}

.table-empty-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 1px solid var(--gray-300);
  display: grid;
  place-items: center;
}

.table-empty-icon span {
  width: 12px;
  height: 12px;
  border: 1px solid var(--gray-300);
  border-radius: 50%;
}

.table-empty-title {
  margin: 0;
  font-size: 14px;
}

.table-empty-hint,
.drawer-subtitle,
.step-description,
.step-summary,
.thread-preview-author,
.thread-preview-text,
.narrative-card p,
.info-banner {
  margin: 0;
  font-size: var(--text-sm);
  color: var(--gray-500);
  line-height: 1.5;
}

.table-collapsed {
  padding: 22px 0;
  text-align: center;
  color: var(--gray-400);
  font-size: var(--text-sm);
}

.table-modal-trigger {
  width: 100%;
  text-align: left;
  padding: 14px 16px;
  border-radius: var(--radius-lg);
  background: var(--glass-normal);
  border: var(--border-glass);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
  transition: all 0.2s ease;
}

.table-modal-trigger:hover {
  background: var(--green-tint-bg);
  border-color: rgba(129, 199, 132, 0.6);
}

.table-modal-trigger h3 {
  margin: 0;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--gray-700);
}

.table-modal-trigger .trigger-hint {
  font-size: var(--text-xs);
  color: var(--gray-400);
}

.drawer {
  position: fixed;
  top: 60px;
  right: 0;
  width: min(400px, 100vw);
  height: calc(100vh - 60px);
  padding: 24px;
  transform: translateX(400px);
  transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: -8px 0 32px rgba(27, 94, 32, 0.08);
  border-top: 0;
  border-right: 0;
  border-bottom: 0;
  border-left: var(--border-glass);
  z-index: 60;
  overflow-y: auto;
}

.drawer.open {
  transform: translateX(0);
}

.drawer-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.drawer-body,
.drawer-form,
.execution-form {
  display: grid;
  gap: 16px;
}

.action-panel {
  padding: 14px 16px;
  display: grid;
  gap: var(--space-2);
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
}

.form-grid label {
  display: grid;
  gap: 6px;
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--gray-500);
}

.form-grid input,
.form-grid select,
.form-grid textarea {
  width: 100%;
  height: 40px;
  padding: 0 12px;
  border-radius: var(--radius-md);
  border: var(--border-glass);
  background: rgba(255, 255, 255, 0.56);
  color: var(--gray-700);
}

.form-grid textarea {
  min-height: 96px;
  padding: 12px;
  resize: vertical;
}

.drawer-form label,
.execution-form label,
.field-inline {
  display: grid;
  gap: 6px;
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--gray-500);
}

.drawer-form input,
.drawer-form select,
.drawer-form textarea,
.execution-form input,
.execution-form select,
.execution-form textarea,
.seed-meta input,
.role-switch-wrap select,
.field-inline select {
  width: 100%;
  height: 40px;
  padding: 0 12px;
  border-radius: var(--radius-md);
  border: var(--border-glass);
  background: rgba(255, 255, 255, 0.56);
  color: var(--gray-700);
}

.drawer-form textarea,
.execution-form textarea,
.reply-form-inline textarea {
  min-height: 96px;
  padding: 12px;
  resize: vertical;
}

.field-span-full {
  grid-column: 1 / -1;
}

.info-banner {
  padding: 10px 12px;
  border-radius: var(--radius-md);
  background: var(--glass-light);
  border: var(--border-glass);
}

.info-banner.success {
  border-left: 4px solid var(--green-500);
}

.info-banner.error {
  border-left: 4px solid var(--red-500);
}

.execution-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 320px;
  gap: var(--space-2);
  align-items: start;
}

.execution-main {
  max-width: 720px;
}

.execution-steps {
  display: grid;
  gap: var(--space-2);
  margin-top: var(--space-2);
}

.step-card {
  padding: 20px;
  transition: opacity 0.2s ease;
}

.step-card.locked {
  opacity: 0.5;
}

.step-card.active {
  box-shadow: inset 3px 0 0 var(--green-500);
}

.step-card.done {
  box-shadow: inset 3px 0 0 var(--green-300);
}

.step-card.restricted {
  box-shadow: inset 3px 0 0 var(--amber-500);
}

.step-header,
.step-title-row,
.step-inline-action,
.micro-stat-row,
.pill-tabs {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.step-header {
  justify-content: space-between;
  align-items: flex-start;
}

.step-index {
  margin: 0 0 8px;
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--gray-400);
}

.step-title-row h3 {
  font-size: var(--text-base);
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--gray-300);
}

.status-dot.active,
.status-dot.done {
  background: var(--green-500);
}

.status-dot.restricted {
  background: var(--amber-500);
}

.progress-shell {
  display: grid;
  gap: 8px;
}

.progress-copy {
  display: flex;
  justify-content: space-between;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--gray-500);
}

.progress-track,
.match-score-track {
  height: 4px;
  border-radius: 999px;
  background: rgba(27, 94, 32, 0.08);
  overflow: hidden;
}

.progress-fill,
.match-score-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(135deg, var(--green-500), var(--green-700));
}

.thread-preview-list {
  display: grid;
  gap: 10px;
}

.thread-preview-item {
  padding: 12px;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.44);
}

.thread-preview-item.outgoing {
  background: rgba(230, 244, 234, 0.7);
}

.thread-preview-author {
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.step-linkish {
  font-size: var(--text-xs);
  color: var(--gray-400);
}

.micro-stat-row {
  padding: 12px 16px;
}

.micro-stat-chip {
  min-width: 92px;
  display: grid;
  gap: 2px;
}

.micro-stat-value {
  font-size: 20px;
  font-weight: 600;
}

.micro-stat-label {
  font-size: var(--text-xs);
  color: var(--gray-500);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.whatsapp-layout {
  display: grid;
  grid-template-columns: 340px minmax(0, 1fr);
  gap: var(--space-3);
  min-height: 0;
}

.phone-column {
  display: grid;
  gap: var(--space-2);
}

.field-inline {
  align-items: center;
}

.phone-frame {
  width: 100%;
  max-width: 340px;
  height: 580px;
  border-radius: 36px;
  background: #1c1c1e;
  padding: 10px;
  box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06), 0 24px 64px rgba(0, 0, 0, 0.3), 0 8px 24px rgba(0, 0, 0, 0.18);
}

.phone-screen {
  width: 100%;
  height: 100%;
  border-radius: 28px;
  background: #ece5dd;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.wa-header {
  height: 56px;
  background: #075e54;
  display: flex;
  align-items: center;
  padding: 0 12px;
  gap: 10px;
  flex-shrink: 0;
}

.wa-avatar {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: linear-gradient(135deg, #25d366, #128c7e);
}

.wa-name {
  font-size: 15px;
  font-weight: 600;
  color: #fff;
}

.wa-status {
  font-size: 11px;
  color: rgba(255, 255, 255, 0.7);
}

.wa-thread {
  flex: 1;
  overflow-y: auto;
  padding: 10px 10px 6px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.wa-bubble {
  max-width: 72%;
  padding: 7px 9px 4px;
  border-radius: 8px;
  font-size: 13px;
  line-height: 1.45;
  color: #3c4043;
}

.wa-bubble.incoming {
  background: #fff;
  border-radius: 0 8px 8px 8px;
  align-self: flex-start;
}

.wa-bubble.outgoing {
  background: #dcf8c6;
  border-radius: 8px 8px 0 8px;
  align-self: flex-end;
}

.wa-intent {
  font-size: 9px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 1px 6px;
  border-radius: 10px;
  background: rgba(7, 94, 84, 0.1);
  color: #075e54;
  display: inline-block;
  margin-top: 3px;
}

.wa-time {
  font-size: 10px;
  color: #9e9e9e;
  text-align: right;
  margin-top: 2px;
}

.wa-input-bar {
  height: 52px;
  background: #f0f2f5;
  padding: 8px 10px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.wa-input {
  flex: 1;
  height: 36px;
  border-radius: 20px;
  background: #fff;
  border: none;
  padding: 0 14px;
  font-size: 13px;
}

.wa-send-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #25d366;
  display: grid;
  place-items: center;
  cursor: pointer;
}

.scenario-pill-row,
.pill-tabs,
.toolbar-actions {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.reply-mode-switch {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.reply-mode-label {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--gray-500);
}

.agent-mode-note {
  margin: 0;
  font-size: var(--text-sm);
  color: var(--gray-500);
}

.pill-tab {
  height: 28px;
  padding: 0 12px;
  border-radius: var(--radius-pill);
  border: 1px solid rgba(203, 230, 200, 0.7);
  background: transparent;
  color: var(--gray-500);
  font-size: var(--text-sm);
  cursor: pointer;
}

.pill-tab.active {
  background: var(--green-tint-bg);
  color: var(--green-700);
}

.office-list,
.comm-inbox-list {
  display: grid;
  gap: 10px;
  margin-top: 12px;
}

.office-row,
.comm-inbox-row {
  width: 100%;
  text-align: left;
  padding: 12px;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.42);
  border: var(--border-subtle);
  cursor: pointer;
  transition: all 0.2s ease;
}

.office-row.selected,
.comm-inbox-row.selected {
  background: var(--green-tint-bg);
  border-color: rgba(76, 175, 80, 0.3);
}

.office-row-main,
.office-row-meta,
.comm-inbox-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
}

.office-row-main strong,
.comm-inbox-row strong {
  font-size: var(--text-sm);
}

.office-row-main span,
.office-row p,
.comm-inbox-row p {
  font-size: var(--text-xs);
  color: var(--gray-500);
  margin: 4px 0 0;
}

.office-thread-panel {
  margin-top: var(--space-2);
  display: grid;
  gap: var(--space-2);
}

.wa-queue-empty {
  margin: 0;
  font-size: var(--text-sm);
  color: var(--gray-500);
}

/* Jira-like office queue */
.jira-board-layout {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.95fr);
  gap: 16px;
  min-height: 580px;
}

.jira-board-panel,
.jira-detail-panel {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 0;
}

.jira-board-panel {
  gap: 12px;
  padding-right: 6px;
}

.jira-board-head {
  display: flex;
  align-items: center;
  gap: 12px;
}

.jira-board-head h3 {
  margin: 0;
  font-size: var(--text-base);
  font-weight: 600;
}

.jira-board-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
  min-height: 0;
}

.jira-lane {
  border-radius: var(--radius-lg);
  border: var(--border-subtle);
  background: rgba(255, 255, 255, 0.28);
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.jira-lane-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
  padding: 12px;
  border-bottom: var(--border-subtle);
}

.jira-lane-head h4 {
  margin: 0;
  font-size: var(--text-sm);
  font-weight: 700;
}

.jira-lane-head p {
  margin: 4px 0 0;
  font-size: var(--text-xs);
  color: var(--gray-500);
}

.jira-lane-count {
  min-width: 28px;
  height: 28px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-xs);
  font-weight: 700;
  background: rgba(255, 255, 255, 0.72);
  color: var(--gray-700);
}

.jira-lane-warn .jira-lane-head {
  background: linear-gradient(180deg, rgba(255, 152, 0, 0.08), transparent);
}

.jira-lane-info .jira-lane-head {
  background: linear-gradient(180deg, rgba(33, 150, 243, 0.08), transparent);
}

.jira-lane-ok .jira-lane-head {
  background: linear-gradient(180deg, rgba(76, 175, 80, 0.08), transparent);
}

.jira-lane-list {
  display: grid;
  gap: 10px;
  padding: 12px;
  overflow-y: auto;
  min-height: 0;
}

.jira-lane-empty {
  margin: 0;
  padding: 14px 12px;
  border-radius: var(--radius-md);
  border: 1px dashed rgba(138, 146, 138, 0.3);
  color: var(--gray-400);
  font-size: var(--text-sm);
  text-align: center;
}

.jira-card {
  width: 100%;
  display: grid;
  gap: 10px;
  padding: 12px;
  border-radius: var(--radius-md);
  border: 1px solid rgba(203, 230, 200, 0.22);
  background: rgba(255, 255, 255, 0.66);
  text-align: left;
  cursor: pointer;
  transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease, background 0.16s ease;
}

.jira-card:hover {
  transform: translateY(-1px);
  box-shadow: 0 10px 24px rgba(27, 94, 32, 0.08);
}

.jira-card.active {
  border-color: rgba(76, 175, 80, 0.4);
  background: rgba(232, 245, 233, 0.9);
  box-shadow: 0 12px 28px rgba(76, 175, 80, 0.12);
}

.jira-card-top,
.jira-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  min-width: 0;
}

.jira-ticket-key {
  font-size: 11px;
  font-weight: 700;
  color: var(--gray-400);
  font-family: monospace;
  letter-spacing: 0.04em;
}

.jira-card-body {
  display: grid;
  gap: 4px;
  min-width: 0;
}

.jira-ticket-summary {
  font-size: var(--text-sm);
  color: var(--gray-700);
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  overflow: hidden;
  -webkit-line-clamp: 3;
}

.jira-ticket-meta,
.jira-ticket-submeta {
  font-size: var(--text-xs);
  color: var(--gray-400);
}

.jira-card-action {
  flex-shrink: 0;
}

/* Detail panel */
.jira-detail-panel {
  position: relative;
  padding-left: 20px;
  border-left: 1px solid rgba(203, 230, 200, 0.34);
}

.jira-detail-panel::before {
  content: "";
  position: absolute;
  left: 0;
  top: 8px;
  bottom: 8px;
  width: 12px;
  background: linear-gradient(180deg, rgba(129, 199, 132, 0.08), rgba(255, 255, 255, 0));
  pointer-events: none;
}

.jira-detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 14px;
  border-bottom: var(--border-subtle);
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.24);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}

.jira-detail-head h4 {
  margin: 0;
  font-size: var(--text-sm);
  font-weight: 600;
}

.jira-detail-id {
  font-size: 11px;
  color: var(--gray-400);
  font-family: monospace;
}

.jira-detail-head-tags {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.jira-detail-body {
  flex: 1;
  overflow-y: auto;
  padding: 12px 14px;
  display: grid;
  gap: 14px;
}

.jira-detail-summary-card {
  display: grid;
  gap: 10px;
  padding: 12px;
  border-radius: var(--radius-md);
  border: var(--border-subtle);
  background: rgba(255, 255, 255, 0.42);
}

.jira-detail-summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  font-size: var(--text-sm);
  color: var(--gray-700);
}

.jira-detail-summary-text {
  align-items: flex-start;
}

.jira-detail-summary-text p {
  margin: 0;
  text-align: right;
  max-width: 70%;
  line-height: 1.5;
}

.jira-detail-field {
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--gray-500);
}

.jira-timeline {
  display: grid;
  gap: 10px;
}

.jira-timeline-item {
  display: grid;
  grid-template-columns: 16px 1fr;
  gap: 10px;
  align-items: start;
}

.jira-timeline-dot {
  width: 12px;
  height: 12px;
  margin-top: 2px;
  border-radius: 50%;
  background: rgba(138, 146, 138, 0.24);
  border: 2px solid rgba(138, 146, 138, 0.34);
}

.jira-timeline-item.is-complete .jira-timeline-dot {
  background: rgba(76, 175, 80, 0.55);
  border-color: rgba(76, 175, 80, 0.4);
}

.jira-timeline-item strong {
  display: block;
  font-size: var(--text-sm);
  color: var(--gray-700);
}

.jira-timeline-item p {
  margin: 2px 0 0;
  font-size: var(--text-xs);
  color: var(--gray-500);
}

.jira-thread {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.jira-msg {
  padding: 10px 12px;
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.5);
}

.jira-msg.outgoing {
  background: rgba(230, 244, 234, 0.7);
}

.jira-msg-author {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--gray-400);
  font-weight: 600;
}

.jira-msg-text {
  margin: 4px 0 0;
  font-size: var(--text-sm);
}

.jira-reply {
  padding: 12px 14px;
  border-top: var(--border-subtle);
  flex-shrink: 0;
}

.jira-reply textarea {
  width: 100%;
  padding: 8px 10px;
  border: var(--border-glass);
  border-radius: var(--radius-md);
  background: rgba(255, 255, 255, 0.6);
  font-family: var(--font-sans);
  font-size: var(--text-sm);
  resize: vertical;
  min-height: 56px;
}

.jira-reply textarea:focus {
  outline: none;
  border-color: rgba(76, 175, 80, 0.5);
}

.jira-reply-actions {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}

.jira-detail-empty {
  flex: 1;
  display: grid;
  place-items: center;
  color: var(--gray-400);
  font-size: var(--text-sm);
}

.badge-warn {
  background: rgba(255, 152, 0, 0.12);
  color: #e65100;
}

.badge-info {
  background: rgba(33, 150, 243, 0.12);
  color: #1565c0;
}

.badge-ok {
  background: rgba(76, 175, 80, 0.12);
  color: #2e7d32;
}

.operations-subnav {
  height: 40px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  gap: 24px;
}

.operations-tab {
  height: 100%;
  padding: 0;
  background: transparent;
  color: var(--gray-600);
  border-bottom: 2px solid transparent;
  cursor: pointer;
  font-size: var(--text-sm);
}

.operations-tab.active {
  color: var(--green-700);
  border-bottom-color: var(--green-500);
}

.intent-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  max-width: 100%;
  min-height: 20px;
  padding: 3px 8px;
  border-radius: var(--radius-pill);
  background: color-mix(in srgb, var(--chip-color) 10%, transparent);
  color: var(--chip-color);
  font-size: var(--text-xs);
  font-weight: 600;
  line-height: 1.1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.match-score-cell {
  display: grid;
  gap: 6px;
  min-width: 92px;
}

.score-header-label {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.score-info-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
  outline: none;
}

.score-info-trigger {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  line-height: 1;
  font-weight: 700;
  color: var(--green-700);
  border: 1px solid rgba(56, 142, 60, 0.4);
  background: rgba(76, 175, 80, 0.12);
}

.score-info-popover {
  position: absolute;
  top: calc(100% + 8px);
  left: -8px;
  width: min(340px, 60vw);
  padding: 8px 10px;
  border-radius: var(--radius-sm);
  border: var(--border-subtle);
  background: rgba(255, 255, 255, 0.96);
  color: var(--gray-700);
  font-size: var(--text-xs);
  letter-spacing: normal;
  line-height: 1.4;
  text-transform: none;
  box-shadow: 0 8px 20px rgba(27, 94, 32, 0.12);
  opacity: 0;
  pointer-events: none;
  transform: translateY(-4px);
  transition: opacity 0.15s ease, transform 0.15s ease;
  z-index: 3;
  white-space: normal;
}

.score-info-wrap:hover .score-info-popover,
.score-info-wrap:focus-visible .score-info-popover {
  opacity: 1;
  transform: translateY(0);
}

.inline-confirm {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: var(--text-xs);
  color: var(--gray-500);
}

.narrative-card p {
  color: var(--gray-600);
}

.narrative-note p {
  font-style: italic;
}

.report-readout {
  padding: 14px 16px;
}

.report-readout p {
  max-width: 680px;
  margin-top: 6px;
  font-size: var(--text-sm);
  color: var(--gray-700);
}

.toast-stack {
  position: fixed;
  bottom: 20px;
  right: 24px;
  z-index: 100;
  display: grid;
  gap: 8px;
  max-width: 400px;
}

.toast-stack:empty {
  display: none;
}

.comm-inbox-list {
  max-height: 420px;
  overflow-y: auto;
}

.comm-column {
  max-height: 580px;
  overflow-y: auto;
}

.thread-preview-list.expanded {
  max-height: 400px;
  overflow-y: auto;
}

.empty-section {
  padding: 14px 16px;
  color: var(--gray-500);
}

.modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 70;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(4px);
  display: grid;
  place-items: center;
  padding: 32px;
  animation: fadeIn 0.18s ease;
}

.modal-panel {
  width: min(920px, 100%);
  max-height: calc(100vh - 64px);
  border-radius: var(--radius-lg);
  background: var(--glass-strong);
  backdrop-filter: blur(24px);
  border: var(--border-glass);
  box-shadow: 0 24px 64px rgba(27, 94, 32, 0.12);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: modalUp 0.22s ease;
}

.modal-panel.modal-wide {
  width: min(1100px, 100%);
}

.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
  padding: 16px 20px;
  border-bottom: var(--border-subtle);
  flex-shrink: 0;
}

.modal-head h3 {
  margin: 0;
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--gray-700);
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 16px 20px;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes modalUp {
  from { opacity: 0; transform: translateY(12px) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-thumb {
  background: rgba(138, 146, 138, 0.3);
  border-radius: 999px;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes meshBreathe {
  0%,
  100% {
    transform: scale(1);
    opacity: 0.08;
  }
  50% {
    transform: scale(1.06);
    opacity: 0.16;
  }
}

@keyframes meshDrift1 {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  50% {
    transform: translate3d(8%, 6%, 0) scale(1.08);
  }
}

@keyframes meshDrift2 {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  50% {
    transform: translate3d(-9%, 7%, 0) scale(1.05);
  }
}

@keyframes meshDrift3 {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  50% {
    transform: translate3d(7%, -6%, 0) scale(1.05);
  }
}

@keyframes meshDrift4 {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }
  50% {
    transform: translate3d(-6%, -4%, 0) scale(1.05);
  }
}

@media (max-width: 1200px) {
  .communication-grid,
  .market-grid,
  .execution-layout,
  .equal-grid {
    grid-template-columns: 1fr;
  }

  .form-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .jira-board-layout {
    grid-template-columns: 1fr;
  }

  .jira-board-grid {
    grid-template-columns: 1fr;
  }

  .communication-jira-shell {
    height: auto;
    max-height: none;
  }

  .communication-jira-shell .jira-board-layout {
    height: auto;
  }

  .jira-detail-panel {
    padding-left: 0;
    padding-top: 16px;
    border-left: 0;
    border-top: 1px solid rgba(203, 230, 200, 0.34);
  }

  .jira-detail-panel::before {
    left: 0;
    right: 0;
    top: 0;
    bottom: auto;
    width: auto;
    height: 12px;
    background: linear-gradient(90deg, rgba(129, 199, 132, 0.08), rgba(255, 255, 255, 0));
  }
}

@media (max-width: 980px) {
  .main-layout,
  .main-layout.nav-collapsed {
    grid-template-columns: 1fr;
  }

  .left-nav {
    position: static;
    margin: 16px;
  }

  .content-wrap {
    padding-top: 0;
  }
}

@media (max-width: 760px) {
  .top-bar {
    height: auto;
    padding: 12px 16px;
    flex-direction: column;
    align-items: stretch;
  }

  .brand-wrap,
  .top-actions {
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .content-wrap {
    padding: 16px;
  }

  .whatsapp-layout,
  .communication-grid {
    grid-template-columns: 1fr;
  }

  .jira-board-head,
  .jira-detail-head,
  .jira-detail-summary-row,
  .jira-card-top,
  .jira-card-bottom,
  .jira-reply-actions {
    flex-direction: column;
    align-items: flex-start;
  }

  .jira-detail-summary-text p {
    max-width: 100%;
    text-align: left;
  }

  .form-grid {
    grid-template-columns: 1fr;
  }
}

.agent-flow-wrapper {
  width: 100%;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
  border-radius: 8px;
  padding: 12px;
}
.agent-flow-svg {
  width: 100%;
  height: auto;
  max-height: 360px;
  display: block;
}
.agent-flow-legend {
  display: flex;
  gap: 18px;
  flex-wrap: wrap;
  font-size: 12px;
  color: #475569;
  padding: 8px 4px 0;
}
.agent-flow-legend i {
  display: inline-block;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  margin-right: 6px;
  vertical-align: middle;
}
.command-toolbar-actions {
  display: flex;
  gap: 12px;
  align-items: center;
}
.command-toggle {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #475569;
}
.agent-ticker {
  display: flex;
  flex-direction: column;
  max-height: 260px;
  overflow-y: auto;
}
.ticker-row {
  display: grid;
  grid-template-columns: 14px 140px 1fr 1fr 140px;
  gap: 10px;
  padding: 8px 6px;
  border-bottom: 1px solid #e2e8f0;
  font-size: 13px;
  align-items: center;
}
.ticker-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
}
.ticker-agent { font-weight: 600; color: #0f172a; }
.ticker-title { color: #334155; }
.ticker-detail { color: #64748b; font-size: 12px; }
.ticker-time { color: #94a3b8; font-size: 11px; text-align: right; }
.ticker-empty {
  padding: 16px;
  color: #94a3b8;
  text-align: center;
}

/* ===== Command Center: agent workforce redesign ===== */
.agent-workforce-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 14px;
  padding: 4px 2px 10px;
}
.agent-person-card {
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-top: 3px solid #94a3b8;
  border-radius: 12px;
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}
.agent-person-card:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08);
}
.agent-person-header {
  display: flex;
  gap: 12px;
  align-items: flex-start;
}
.agent-person-figure {
  position: relative;
  width: 54px;
  height: 60px;
  flex-shrink: 0;
}
.person-svg {
  width: 100%;
  height: 100%;
  display: block;
}
.person-pulse {
  transform-origin: 32px 36px;
  animation: personPulse 1.6s ease-out infinite;
}
@keyframes personPulse {
  0%   { transform: scale(0.85); opacity: 0.35; }
  70%  { transform: scale(1.25); opacity: 0; }
  100% { transform: scale(1.25); opacity: 0; }
}
.agent-status-dot {
  position: absolute;
  bottom: 6px;
  right: 2px;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  border: 2px solid #ffffff;
  box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.08);
}
.agent-person-meta { flex: 1; min-width: 0; }
.agent-person-name {
  font-weight: 700;
  font-size: 14px;
  color: #0f172a;
}
.agent-person-role {
  font-size: 11.5px;
  color: #64748b;
  margin-top: 2px;
}
.agent-person-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 8px;
}
.chip {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 999px;
  background: #f1f5f9;
  color: #334155;
  font-weight: 500;
}
.chip-done { background: #ecfdf5; color: #047857; }
.chip-pending { background: #fef3c7; color: #b45309; }
.chip-clear { background: #f1f5f9; color: #64748b; }
.chip-status { background: #ffffff; border: 1px solid #e2e8f0; font-weight: 600; }

.agent-person-current {
  background: #f8fafc;
  border-radius: 8px;
  padding: 10px;
}
.agent-current-label {
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: #94a3b8;
  margin-bottom: 4px;
  font-weight: 600;
}
.agent-current-title {
  font-size: 12.5px;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.3;
}
.agent-current-detail {
  font-size: 11.5px;
  color: #475569;
  margin-top: 3px;
  line-height: 1.35;
}
.agent-current-age {
  font-size: 10.5px;
  color: #94a3b8;
  margin-top: 4px;
}
.agent-current-empty {
  font-size: 12px;
  color: #94a3b8;
  font-style: italic;
}
.agent-person-recent {
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.agent-recent-row {
  display: grid;
  grid-template-columns: 6px 1fr auto;
  gap: 8px;
  align-items: center;
  font-size: 11.5px;
}
.agent-recent-bullet {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}
.agent-recent-title {
  color: #334155;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.agent-recent-status {
  color: #94a3b8;
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}
.agent-recent-empty {
  font-size: 11px;
  color: #cbd5e1;
  font-style: italic;
}

.flow-canvas-divider {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 12px 2px 8px;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  color: #94a3b8;
  font-weight: 600;
}
.flow-canvas-divider::before,
.flow-canvas-divider::after {
  content: "";
  flex: 1;
  height: 1px;
  background: #e2e8f0;
}
.flow-canvas-wrap {
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 10px;
}
.flow-canvas-svg {
  width: 100%;
  height: auto;
  display: block;
}

/* ===== Command page cohesive layout ===== */
.command-page { gap: var(--space-3); }

.command-hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: var(--space-2);
  align-items: stretch;
}
.command-hero-kpis {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: var(--space-2);
}
.command-hero-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  gap: 10px;
  padding: 4px 0;
}
.command-hero-actions .btn-primary { white-space: nowrap; }

@media (max-width: 1100px) {
  .command-hero { grid-template-columns: 1fr; }
  .command-hero-kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .command-hero-actions { flex-direction: row; align-items: center; justify-content: flex-end; }
}

.content-block-hint {
  font-size: var(--text-xs);
  color: var(--gray-500);
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.command-workforce { padding: 14px 14px 18px; }
